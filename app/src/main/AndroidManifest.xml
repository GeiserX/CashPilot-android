<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS"
        android:protectionLevel="signature|privileged|development|appop|retailDemo" />
    <uses-permission android:name="android.permission.READ_NETWORK_USAGE_HISTORY" />

    <!-- Package visibility: required on Android 11+ to query third-party apps -->
    <queries>
        <package android:name="com.honeygain.app" />
        <package android:name="com.bright.earnapp" />
        <package android:name="com.iproyal.pawns" />
        <package android:name="network.mysterium.vpn" />
        <package android:name="com.packetstream.android" />
        <package android:name="com.traffmonetizer.client" />
        <package android:name="com.repocket.android" />
        <package android:name="com.peer2profit.app" />
        <package android:name="com.bytelixir.app" />
        <package android:name="com.bytebenefit.app" />
        <package android:name="com.getgrass.android" />
        <package android:name="com.gaga.gaganode" />
        <package android:name="com.titan.network" />
        <package android:name="io.nodle.cash" />
        <package android:name="com.passiveincome.app" />
        <package android:name="com.uprock.android" />
        <package android:name="com.wipter.app" />
    </queries>

    <application
        android:name=".CashPilotApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.CashPilotAndroid">

        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.CashPilotAndroid">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Notification Listener — detects foreground notifications from monitored apps -->
        <service
            android:name=".service.AppNotificationListener"
            android:exported="true"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

        <!-- Heartbeat foreground service — sends periodic status to CashPilot server -->
        <service
            android:name=".service.HeartbeatService"
            android:exported="false"
            android:foregroundServiceType="specialUse" />

        <!-- Boot receiver — restart heartbeat after reboot -->
        <receiver
            android:name=".service.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

    </application>
</manifest>
